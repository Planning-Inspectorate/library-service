<?php

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_node_access().
 */
function pins_content_access_node_access(NodeInterface $node, string $op, AccountInterface $account) {
  if ($op !== 'view') {
    return AccessResult::neutral();
  }

  if (!in_array($node->bundle(), ['kl_document', 'kl_compound_document'], TRUE)) {
    return AccessResult::neutral();
  }

  if (!$node->hasField('field_restrict_to_admin_only')) {
    return AccessResult::neutral();
  }

  $is_restricted = (bool) $node->get('field_restrict_to_admin_only')->value;
  if (!$is_restricted) {
    return AccessResult::neutral();
  }

  $is_admin = $account->hasRole('administrator') || $account->hasPermission('bypass node access');
  if ($is_admin) {
    return AccessResult::allowed()->cachePerPermissions();
  }

  return AccessResult::forbidden()->cachePerPermissions();
}

/**
 * Implements hook_views_query_alter().
 */
function pins_content_access_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  if (!$query instanceof Sql) {
    return;
  }

  $base_table = $view->storage->get('base_table');
  if (!in_array($base_table, ['node_field_data', 'node_field_revision'], TRUE)) {
    return;
  }

  $account = \Drupal::currentUser();
  if ($account->hasRole('administrator') || $account->hasPermission('bypass node access')) {
    return;
  }

  $node_table_alias = $query->ensureTable('node_field_data');
  if (empty($node_table_alias)) {
    return;
  }

  $query->addWhereExpression(
    0,
    "($node_table_alias.type NOT IN ('kl_document', 'kl_compound_document') OR NOT EXISTS (
      SELECT 1
      FROM {node__field_restrict_to_admin_only} restricted
      WHERE restricted.entity_id = $node_table_alias.nid
        AND restricted.deleted = 0
        AND restricted.field_restrict_to_admin_only_value = 1
    ))"
  );
}
