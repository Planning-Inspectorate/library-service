<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_form_alter().
 */
function pins_folder_hs_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (!in_array($form_id, ['node_kl_document_form', 'node_kl_compound_document_form'], TRUE)) {
    return;
  }

  $form['#attached']['library'][] = 'pins_folder_hs/pins_folder_hs_js_alt_title';

  // Ensure AJAX works with limited validation.
  $form_state->setProcessInput(TRUE);

  // Wrap metadata fields.
  pins_folder_hs_wrap_metadata_fields($form);

  // Attach AJAX to folder field.
  pins_folder_hs_attach_ajax($form);

  // Get selected folder.
  $selected_items = pins_folder_hs_extract_folder_selection($form_state);

  if (!empty($selected_items)) {
    pins_folder_hs_apply_metadata($form_state, $selected_items);
  }
  else {
    pins_folder_hs_clear_all_metadata($form_state);
  }

  $form_state->setRebuild(TRUE);

  if ($form_id === 'node_kl_compound_document_form') {
    $form['#attached']['library'][] = 'pins_folder_hs/pins_folder_hs_js_lib';
  }
}

/**
 * Wrap metadata fields in a container.
 */
function pins_folder_hs_wrap_metadata_fields(array &$form) {
  $fields = [
    'field_kl_authors',
    'field_kl_series',
    'field_kl_classification',
    'field_kl_reading_lists',
    'field_volume',
  ];

  $anchor = 'field_alternative_title';
  $weight = $form[$anchor]['#weight'] ?? 0;
  $group = $form[$anchor]['#group'] ?? 'group_categories';

  $form['metadata_wrapper'] = [
    '#type' => 'container',
    '#attributes' => ['id' => 'metadata-fields-wrapper'],
    '#weight' => 30, // Ensure it appears after the folder field.
    '#group' => $group,
  ];

  foreach ($fields as $field) {
    if (isset($form[$field])) {
      $form['metadata_wrapper'][$field] = $form[$field];
      unset($form['metadata_wrapper'][$field]['#group']);
      unset($form[$field]);
    }
  }
}

/**
 * Attach AJAX behaviour.
 */
function pins_folder_hs_attach_ajax(array &$form) {
  if (!isset($form['field_kl_doc_folder']['widget'][0]['target_id'])) {
    return;
  }

  $form['field_kl_doc_folder']['widget'][0]['target_id']['#ajax'] = [
    'callback' => 'pins_folder_hs_ajaxcallback',
    'event' => 'change',
    'wrapper' => 'metadata-fields-wrapper',
  ];

  $form['field_kl_doc_folder']['widget'][0]['target_id']['#limit_validation_errors'] = [];
}

/**
 * AJAX callback.
 */
function pins_folder_hs_ajaxcallback(array &$form, FormStateInterface $form_state) {
  return $form['metadata_wrapper'];
}

/**
 * Extract selected folder (safe for AJAX + widget variations).
 */
function pins_folder_hs_extract_folder_selection(FormStateInterface $form_state) {
  $input = $form_state->getUserInput();
  $raw = $input['field_kl_doc_folder'] ?? NULL;

  if (empty($raw)) {
    return [];
  }

  if (isset($raw['target_id'])) {
    return [$raw];
  }

  if (isset($raw[0]['target_id'])) {
    return $raw;
  }

  return [];
}

/**
 * Apply metadata from selected folder.
 */
function pins_folder_hs_apply_metadata(FormStateInterface $form_state, array $items) {
  foreach ($items as $item) {
    $tid = $item['target_id'] ?? NULL;
    if (!$tid) {
      continue;
    }

    $term = \Drupal::entityTypeManager()
      ->getStorage('taxonomy_term')
      ->load($tid);

    if (!$term instanceof TermInterface) {
      continue;
    }

    $parents = pins_folder_hs_get_parent_term_ids($tid);

    // Simple fields.
    pins_folder_hs_set_value($form_state, 'field_volume',
      pins_folder_hs_get_field_value($term, 'field_volume'), 'string');

    // Reference fields.
    foreach ([
      'field_kl_authors',
      'field_kl_series',
      'field_kl_classification',
      'field_kl_reading_lists',
    ] as $field) {

      $values = array_unique(array_merge(
        pins_folder_hs_get_field_values($parents, $field),
        pins_folder_hs_get_referenced_entities($term, $field)
      ));

      pins_folder_hs_set_value($form_state, $field, array_values($values), 'options');
    }
  }
}

/**
 * Clear all metadata fields.
 */
function pins_folder_hs_clear_all_metadata(FormStateInterface $form_state) {
  foreach (['field_alternative_title', 'field_volume'] as $field) {
    pins_folder_hs_set_value($form_state, $field, '', 'string');
  }

  foreach ([
    'field_kl_authors',
    'field_kl_series',
    'field_kl_classification',
    'field_kl_reading_lists',
  ] as $field) {
    pins_folder_hs_set_value($form_state, $field, [], 'options');
  }
}

/**
 * Set value in form_state + user_input.
 */
function pins_folder_hs_set_value(FormStateInterface $form_state, $field, $value, $type) {
  $form_state->setValue($field, $value);
  $input = $form_state->getUserInput();

  if ($type === 'string') {
    if (isset($input[$field]['widget'][0])) {
      $input[$field]['widget'][0]['value'] = $value ?? '';
    }
    else {
      $input[$field][0]['value'] = $value ?? '';
    }
  }
  else {
    $input[$field] = $value;
  }

  $form_state->setUserInput($input);
}

/**
 * Get parent term IDs recursively.
 */
function pins_folder_hs_get_parent_term_ids($tid, array &$parents = []) {
  $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);

  if ($term instanceof TermInterface) {
    foreach ($term->parent->referencedEntities() as $parent) {
      $pid = $parent->id();
      if (!in_array($pid, $parents, TRUE)) {
        $parents[] = $pid;
        pins_folder_hs_get_parent_term_ids($pid, $parents);
      }
    }
  }

  return $parents;
}

/**
 * Helpers.
 */
function pins_folder_hs_get_field_value(TermInterface $term, $field) {
  return $term->get($field)->value ?? NULL;
}

function pins_folder_hs_get_field_values(array $tids, $field) {
  $values = [];

  foreach ($tids as $tid) {
    $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
    if ($term instanceof TermInterface && $term->hasField($field)) {
      foreach ($term->get($field)->referencedEntities() as $e) {
        $values[] = $e->id();
      }
    }
  }

  return array_unique($values);
}

function pins_folder_hs_get_referenced_entities(TermInterface $term, $field) {
  return array_map(fn($e) => $e->id(), $term->get($field)->referencedEntities());
}
